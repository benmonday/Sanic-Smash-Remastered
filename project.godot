; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sanic Smash Remastered"
config/version="1.0"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/show_image=false
config/icon="res://assets/images/ui/game_icon.png"

[autoload]

Music="*res://scenes/music.tscn"
SniperSfx="*res://scenes/sniper_sfx.tscn"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/mode=3
window/stretch/mode="viewport"
window/stretch/scale=2.0
window/vsync/vsync_mode=0
mouse_cursor/custom_image="res://assets/images/sprites/cursor64x.png"
mouse_cursor/custom_image_hotspot=Vector2(32, 32)

[global_group]

Holes="Spawn Points for Sanic"
Sanics=""
Sniper=""
"Object Spawn Points"=""

[input]

click={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":1,"position":Vector2(325, 11),"global_position":Vector2(334, 57),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false,"script":null)
]
}

[rendering]

textures/canvas_textures/default_texture_filter=0
